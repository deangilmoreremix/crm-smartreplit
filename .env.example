# Server Environment Variables (for local development)
# These should NOT be committed to the repository
# For production, set these in Netlify Environment Variables

# Database (Supabase PostgreSQL)
# IMPORTANT: Replace with your actual Supabase connection string
# Format: postgresql://postgres:YOUR_PASSWORD@db.bzxohkrxcwodllketcpz.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD_HERE@your-project.supabase.co:5432/postgres

# Supabase (Server-side - keep these secure)
# Get these from your Supabase project settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# API Keys (Server-side only)
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Server Configuration
PORT=5000
AGENTMEMORY_URL=http://localhost:3111

# =================================================================
# CLIENT-SIDE ENVIRONMENT VARIABLES (VITE_ prefixed)
# These go in client/.env for local development
# For production, set VITE_ variables in Netlify

# Supabase (Client-side - safe to expose)
# These are the anon/public key — ok to commit
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY_HERE

# Development bypass (only for local development - NEVER in production)
# CHANGE THIS to a strong unique value for your environment
VITE_DEV_BYPASS_PASSWORD=CHANGE_THIS_DEV_BYPASS_PASSWORD

# Note: Sensitive API keys (OpenAI, Gemini, ElevenLabs) are now handled server-side only
# They should NOT have VITE_ prefix to prevent exposure in client bundle
# Configure these in server environment variables instead

# Module Federation Configuration
# Set to 'true' to enable loading remote micro-frontends
VITE_ENABLE_MFE=true
VITE_USE_IFRAME_FALLBACK=true